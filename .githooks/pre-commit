#!/usr/bin/env bash
#
# Pre-commit hook — runs `npm run lint` before letting the commit through.
#
# Mirrors the CI step (`Run npm run lint`) so the kind of unused-import
# / unused-var error that escaped commit f4c83a1 fails locally instead of
# burning a CI minute.
#
# Activated by `npm install` via the `prepare` script in package.json
# (`git config core.hooksPath .githooks`).
#
# To skip on a single commit (rare — e.g. WIP push before fixing): use
# `git commit --no-verify`.

set -e

# Always operate from the repo root, regardless of cwd at commit time.
cd "$(git rev-parse --show-toplevel)"

echo "→ pre-commit: running lint…"
npm run lint
echo "✓ lint clean"
