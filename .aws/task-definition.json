{
  "family": "jko-backend",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/jko_ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "jko-backend",
      "image": "REPLACE_ON_DEPLOY",
      "essential": true,
      "portMappings": [
        {
          "name": "api",
          "containerPort": 3001,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" },
        { "name": "HOST", "value": "0.0.0.0" },
        { "name": "LOG_LEVEL", "value": "info" },

        { "name": "DB_HOST", "value": "REPLACE_EC2_PRIVATE_IP" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USER", "value": "jko_vm" },
        { "name": "DB_NAME", "value": "jkodonation" },
        { "name": "DB_SCHEMA", "value": "public" },
        { "name": "DB_SSL_MODE", "value": "" },

        { "name": "JWT_ACCESS_EXPIRES_IN", "value": "3h" },
        { "name": "JWT_REFRESH_EXPIRES_IN", "value": "30d" },
        { "name": "JWT_ISSUER", "value": "http://api:3001" },

        { "name": "GOOGLE_CALLBACK_URL", "value": "http://localhost:3000/api/auth/google/callback" },
        { "name": "OIDC_DISCOVERY_URL", "value": "https://accounts.google.com/.well-known/openid-configuration" },

        { "name": "PASSWORD_HASH_MEMORY_COST", "value": "19456" },
        { "name": "PASSWORD_HASH_TIME_COST", "value": "2" },
        { "name": "PASSWORD_HASH_PARALLELISM", "value": "1" },
        { "name": "PASSWORD_MIN_LENGTH", "value": "8" },

        { "name": "LOGIN_LOCK_THRESHOLD", "value": "10" },
        { "name": "LOGIN_LOCK_WINDOW_SEC", "value": "900" },

        { "name": "RATE_LIMIT_GLOBAL_PER_IP_LIMIT", "value": "600" },
        { "name": "RATE_LIMIT_GLOBAL_PER_IP_WINDOW_SEC", "value": "60" },
        { "name": "RATE_LIMIT_DEFAULT_LIMIT", "value": "120" },
        { "name": "RATE_LIMIT_DEFAULT_WINDOW_SEC", "value": "60" },
        { "name": "RATE_LIMIT_FAILURE_MODE", "value": "closed" },
        { "name": "RATE_LIMIT_TRUSTED_PROXIES", "value": "" },

        { "name": "CORS_ORIGIN", "value": "http://localhost:3000" },
        { "name": "CORS_PREFLIGHT_MAX_AGE_SEC", "value": "600" },

        { "name": "HSTS_MAX_AGE_SEC", "value": "31536000" },
        { "name": "HSTS_INCLUDE_SUBDOMAINS", "value": "true" },
        { "name": "HSTS_PRELOAD", "value": "false" }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:POSTGRES_PASSWORD::"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:REDIS_PASSWORD::"
        },
        {
          "name": "JWT_ACCESS_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:JWT_ACCESS_SECRET::"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:JWT_REFRESH_SECRET::"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:GOOGLE_CLIENT_ID::"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:GOOGLE_CLIENT_SECRET::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jko-backend",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
