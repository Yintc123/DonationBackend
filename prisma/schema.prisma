// Spec 003 (ORM) + ADR 003 (PostgreSQL) + ADR 007 (Prisma)
// + spec 007 §10 (Account ↔ Credential identity model).
//
// Minimum model needed for spec 008 (password flow). GoogleCredential
// lands with spec 007 — same Account, second Credential row.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Spec 007 §10.1 — the canonical "person" in the service.
// Email is unique and serves as the human-facing identifier.
model Account {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordCredential PasswordCredential?

  @@map("accounts")
}

// Spec 008 §4 / spec 007 §10.1 — one PasswordCredential per Account.
// hashAlgo lets us silently rehash on login when params upgrade
// (spec 008 §3.1).
model PasswordCredential {
  id             String   @id @default(uuid())
  accountId      String   @unique
  hashedPassword String
  hashAlgo       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}
