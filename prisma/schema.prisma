// Spec 003 (ORM) + ADR 003 (PostgreSQL) + ADR 007 (Prisma)
// + spec 007 §10 (Account ↔ Credential identity model).
//
// Account has 0..1 PasswordCredential (spec 008) AND 0..1
// GoogleCredential (spec 007). At least one credential should
// always be present after registration (linking flow guarantees this).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Spec 007 §10.1 — the canonical "person" in the service.
// Email is unique and serves as the human-facing identifier.
model Account {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordCredential PasswordCredential?
  googleCredential   GoogleCredential?

  @@map("accounts")
}

// Spec 008 §4 / spec 007 §10.1 — one PasswordCredential per Account.
// hashAlgo lets us silently rehash on login when params upgrade
// (spec 008 §3.1).
model PasswordCredential {
  id             String   @id @default(uuid())
  accountId      String   @unique
  hashedPassword String
  hashAlgo       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

// Spec 007 §10.1 — one GoogleCredential per Account; externalId is the
// Google `sub` claim and must be globally unique so a single Google
// identity cannot link to multiple Accounts (§10.1 / §10.5).
model GoogleCredential {
  id         String   @id @default(uuid())
  accountId  String   @unique
  externalId String   @unique
  email      String
  linkedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("google_credentials")
}
