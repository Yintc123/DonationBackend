// Spec 003 (ORM) + ADR 003 (PostgreSQL) + ADR 007 (Prisma)
// + spec 007 §10 (Account ↔ Credential identity model).
//
// Account has 0..1 PasswordCredential (spec 008) AND 0..1
// GoogleCredential (spec 007). At least one credential should
// always be present after registration (linking flow guarantees this).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Spec 007 §10.1 — the canonical "person" in the service.
//
// Identifier model (v0.4 — spec 007 §10.1):
//   - `username` is the primary identifier for password registration. Both
//     `username` and `email` are nullable to support multiple registration
//     paths (username-only password register, email-only Google sign-in).
//     A new password account ALWAYS sets `username`; a new Google account
//     ALWAYS sets `email`. The application enforces "at least one of
//     username or email" at the registration handlers; the DB allows null
//     on either column to keep both paths additive.
//   - Both columns are unique when present (PG treats multiple nulls as
//     non-conflicting).
//
// Audit columns (v0.2 — spec 007 §10.8):
//   - `lastLoginAt` / `lastLoginType` set on register, password login,
//     successful Google exchange (login intent / new-account branches).
//
// Lifecycle columns (v0.4 — spec 007 §10.9):
//   - `displayOrder` for the (future) admin user-list UI. No domain
//     semantics today; kept aligned with the Charity / Project / SaleItem
//     pattern so the admin table renderer can reuse one sort helper.
//   - `archivedAt` / `deletedAt` represent "account disabled" — login and
//     refresh paths reject either non-null with 401 AUTH_ACCOUNT_DISABLED.
//     We do NOT eagerly sweep refresh tokens; the per-request check on
//     /auth/refresh catches them on next use (spec 007 §10.9).
model Account {
  id            String     @id @default(uuid())
  username      String?    @unique
  email         String?    @unique
  // Spec 020 v0.2 §2.3 — role gate for admin write endpoints.
  // `0 = ADMIN`, `1 = USER` (literal const in src/lib/auth/role.ts, not a
  // Prisma enum — demo-stable role set; future MODERATOR / SUPPORT splits
  // will upgrade to an enum at that time). Default 1 so any new register
  // path is USER; existing rows are backfilled to 1 by the migration.
  role          Int        @default(1)
  displayOrder  Int        @default(0)
  archivedAt    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?
  lastLoginType LoginType?

  passwordCredential PasswordCredential?
  googleCredential   GoogleCredential?

  @@map("accounts")
}

// Spec 007 §10.2 — enum for `Account.lastLoginType`. Add new values when
// a new credential type ships (e.g. Apple, GitHub) — both a schema change
// AND a migration step. Prefer enum over string for type-safety at the
// Prisma client surface; the value set is short and rarely changes.
enum LoginType {
  PASSWORD
  GOOGLE
}

// Spec 008 §4 / spec 007 §10.1 — one PasswordCredential per Account.
// hashAlgo lets us silently rehash on login when params upgrade
// (spec 008 §3.1).
model PasswordCredential {
  id             String   @id @default(uuid())
  accountId      String   @unique
  hashedPassword String
  hashAlgo       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

// Spec 007 §10.1 — one GoogleCredential per Account; externalId is the
// Google `sub` claim and must be globally unique so a single Google
// identity cannot link to multiple Accounts (§10.1 / §10.5).
model GoogleCredential {
  id         String   @id @default(uuid())
  accountId  String   @unique
  externalId String   @unique
  email      String
  linkedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("google_credentials")
}

// =============================================================================
// Spec 015 v0.9 — Donation domain
//
// Charity (主表) 1 ── N DonationProject  (FK NOT NULL, onDelete: Restrict)
//                1 ── N SaleItem         (FK NOT NULL, onDelete: Restrict)
//                M ── N Category         (透過 CharityOnCategory join,Charity Cascade / Category Restrict)
//
// Lifecycle 欄位由 backend ADR 006 統一定錨:
//   displayOrder / archivedAt / deletedAt / publishStartAt / publishEndAt
// 三主 entity 都有;Category 只有 archivedAt / deletedAt;CharityOnCategory 無。
// 公開 list / detail query 必須走 service-layer `whereLive(now)` helper,
// Project / SaleItem 額外 cascade parent Charity 的 whereLive(子表自動隨
// 合作合約過期而消失,續約自動恢復)。
//
// 多語系:中文主語 NOT NULL,英文 suffix columns nullable(ADR 004)。
// 圖片:DB 存 S3 key,API 層用 `objectUrl(key)` 拼 URL(spec 018)。
// =============================================================================

model Charity {
  id              String    @id @default(uuid())
  // 多語系欄位(ADR 004 — Pattern A suffix columns)
  name            String    @db.VarChar(120)
  description     String    @db.VarChar(500)
  nameEn          String?   @db.VarChar(120)
  descriptionEn   String?   @db.VarChar(500)
  // 圖片(spec 018 §5.1 key pattern;API 層 objectUrl() 拼 URL)
  logoKey         String?   @db.VarChar(512)
  // 補件揭露欄位(IMG_4876)
  contactPhone    String?   @db.VarChar(40)
  contactEmail    String?   @db.VarChar(254)
  officialWebsite String?   @db.VarChar(2048)
  approvalNo      String?   @db.VarChar(80)
  // Lifecycle 欄位(ADR 006)
  displayOrder    Int       @default(0)
  archivedAt      DateTime?
  deletedAt       DateTime?
  publishStartAt  DateTime?
  publishEndAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  donationProjects DonationProject[]
  saleItems        SaleItem[]
  categories       CharityOnCategory[]
  // spec 021 §3.1 — reverse relation for OrderLine.charityId. Pure
  // Prisma-client concept (no SQL DDL emitted).
  orderLines       OrderLine[]

  // Public list 主路徑(whereLive 通過後 ORDER BY displayOrder, createdAt, id)
  @@index([displayOrder, createdAt(sort: Desc), id(sort: Desc)])
  // 排程下架 sweep / 過期 query
  @@index([publishEndAt])
  // Admin 全量(允許看 archived / deleted)
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@map("charities")
}

model DonationProject {
  id                String    @id @default(uuid())
  charityId         String
  // 多語系欄位
  name              String    @db.VarChar(120)
  description       String    @db.VarChar(500)
  nameEn            String?   @db.VarChar(120)
  descriptionEn     String?   @db.VarChar(500)
  // 圖片
  logoKey           String?   @db.VarChar(512)
  coverImageKey     String?   @db.VarChar(512)
  // 詳情頁長文 + 字號
  content           String    @db.Text
  contentEn         String?   @db.Text
  raisingApprovalNo String?   @db.VarChar(80)
  reliefApprovalNo  String?   @db.VarChar(80)
  // Lifecycle
  displayOrder      Int       @default(0)
  archivedAt        DateTime?
  deletedAt         DateTime?
  publishStartAt    DateTime?
  publishEndAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  charity    Charity     @relation(fields: [charityId], references: [id], onDelete: Restrict)
  // spec 021 §3.1 — reverse relation for OrderLine.donationProjectId.
  orderLines OrderLine[]

  // FK lookup(`include: { charity: true }` 用)
  @@index([charityId])
  // Public list 主路徑(whereLive + parent whereLive 後排序)
  @@index([charityId, displayOrder, createdAt(sort: Desc), id(sort: Desc)])
  // 排程下架 sweep
  @@index([publishEndAt])
  // Admin 全量
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@map("donation_projects")
}

model SaleItem {
  id                String    @id @default(uuid())
  charityId         String
  // 多語系欄位
  name              String    @db.VarChar(120)
  description       String    @db.VarChar(500)
  nameEn            String?   @db.VarChar(120)
  descriptionEn     String?   @db.VarChar(500)
  // 圖片
  logoKey           String?   @db.VarChar(512)
  coverImageKey     String?   @db.VarChar(512)
  // 義賣商品專屬
  priceTwd          Int
  content           String    @db.Text
  contentEn         String?   @db.Text
  raisingApprovalNo String?   @db.VarChar(80)
  reliefApprovalNo  String?   @db.VarChar(80)
  // Lifecycle
  displayOrder      Int       @default(0)
  archivedAt        DateTime?
  deletedAt         DateTime?
  publishStartAt    DateTime?
  publishEndAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  charity    Charity     @relation(fields: [charityId], references: [id], onDelete: Restrict)
  // spec 021 §3.1 — reverse relation for OrderLine.saleItemId.
  orderLines OrderLine[]

  @@index([charityId])
  @@index([charityId, displayOrder, createdAt(sort: Desc), id(sort: Desc)])
  @@index([publishEndAt])
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@map("sale_items")
}

// 分類字典表(spec 015 §7.1 16 筆固定;不加 publish 時間 — 字典表無合作期限)
model Category {
  id            String    @id @default(uuid())
  key           String    @unique @db.VarChar(40)
  displayName   String    @db.VarChar(80)
  displayNameEn String?   @db.VarChar(80)
  displayOrder  Int       @default(0)
  archivedAt    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  charities CharityOnCategory[]

  @@index([displayOrder])
  @@map("categories")
}

// Charity ↔ Category 的 M:N join 表
// onDelete 不對稱:
//   - charityId → charities Cascade(Charity 刪除時 join 列無意義,自動清掉)
//   - categoryId → categories Restrict(字典項被使用中不能直接刪,強制管理員先解除掛載)
// 不加 lifecycle 欄位 — 刪 join 列即 unassign,真要 audit 另開 table
model CharityOnCategory {
  charityId  String
  categoryId String
  assignedAt DateTime @default(now())

  charity  Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([charityId, categoryId])
  @@index([categoryId])
  @@map("charity_categories")
}

// =============================================================================
// Spec 021 v0.7 — Donation Order domain (Order header + OrderLine pattern)
//
// Order(header) ── 1..N OrderLine(線項,本期僅 1 條,spec 022 §11 OQ #3)
//
// OrderLine 走 polymorphic FK + subjectType discriminator(spec 021 §2.2):
//   subjectType = CHARITY          → charityId 非 null
//   subjectType = DONATION_PROJECT → donationProjectId 非 null
//   subjectType = SALE_ITEM        → saleItemId 非 null
// 三 FK 互斥(application-level invariant,validators.ts;見 spec 021 §7.1)
//
// 訂單匿名(spec 021 §2.1):Order 不關聯 Account,donorName 自由字串。
// Account 表此後僅服務 admin(role=0,spec 020)。
//
// Hard delete(spec 021 §10 OQ #7):訂單為事實紀錄,無 archive / restore;
// admin DELETE 直接從 DB 移除(Cascade 刪 OrderLine)。
// =============================================================================

// spec 021 §3 — 訂單狀態 state machine(spec 021 §5):
//   PENDING → PAID(confirm-payment) | CANCELLED(user cancel)
//   PAID    → REFUNDED(admin PATCH)
//   FAILED  — 本期不主動觸發,留欄位給未來真 gateway timeout
enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
  REFUNDED
}

// spec 021 §3 — OrderLine.subjectType discriminator。
// 新增 subject type 走 schema migration:加 enum value + 加 nullable FK(在
// OrderLine 上)+ 加 validators.ts 的 switch case。Order 表不動(§2.2)。
enum OrderSubjectType {
  CHARITY
  DONATION_PROJECT
  SALE_ITEM
}

// spec 021 §3 — 單次 vs 月扣。對 SALE_ITEM 必為 null(§7.2 invariant)。
enum DonationFrequency {
  ONE_TIME
  RECURRING
}

// spec 021 §3 — RECURRING 訂閱的月扣款日(對應 Figma IMG_4885/4886 三選一)。
// 只有三個日期(6 / 16 / 26),所有月份都存在,本期不需處理 31 號 edge case。
enum BillingDay {
  DAY_6
  DAY_16
  DAY_26
}

// spec 021 §3 / IMG_4888-4890 — 收據開立方式。
// CHARITY / DONATION_PROJECT 必填;SALE_ITEM 必為 null(§7.5 invariant,
// 且由 spec 022 §4.3 / §5.1 在 TypeBox 層 additionalProperties: false 擋下)。
enum ReceiptOption {
  NONE
  INDIVIDUAL
  CORPORATE
  GOVERNMENT_DONATION
  DEFER
}

// spec 021 §3 — Order header(entity-agnostic;subject 細節下到 OrderLine)。
model Order {
  id     String      @id @default(uuid())
  status OrderStatus @default(PENDING)

  // 訂單匿名 — 自由字串,不引用 Account.id(§2.1)。
  donorName String @db.VarChar(120)

  // 三類訂單共用 isAnonymous(IMG_4890 checkbox)。影響 public display(由
  // BFF / UI 端做 anonymization,backend response 一律回原樣,見 spec 022 §4.6)。
  isAnonymous Boolean @default(false)

  // 收據開立方式 — CHARITY/PROJECT 必填,SALE_ITEM 必為 null(§7.5)。
  receiptOption ReceiptOption?

  // 訂單備注(整單共用,**不** per-line)。service 層 trim 後空白 → null(spec 022 §5.2)。
  note String? @db.VarChar(500)

  // 下次扣款日 — 僅 RECURRING 有值,backend 算 + 存(§7.7),本期不做 cron 扣款。
  // create 時算一次,後續任何 PATCH 都不重算(§7.7 重算規約)。
  nextChargeAt DateTime?

  // 訂單總金額(denormalized:= sum(OrderLine.subtotalTwd))。
  // 本期 OrderLine immutable post-create,所以 amountTwd 算一次就鎖。
  amountTwd Int

  paidAt      DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines OrderLine[]

  // Admin list `?status=X` + ORDER BY createdAt(spec 022 §4.7)。
  @@index([status, createdAt])
  // 未來 cron「找出今日該扣款的 order」走此 index(本期 cron 不存在)。
  @@index([nextChargeAt])
  @@map("orders")
}

// spec 021 §3 — OrderLine 線項。
// 本期 1 條/單(spec 021 §1.4 + §7.4 invariant);未來 cart 開放 N 條。
model OrderLine {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Subject 多型對應(§2.2 polymorphic FK 方案)。
  subjectType OrderSubjectType

  // Polymorphic FK — 三 nullable typed columns 保 DB integrity。
  // onDelete: Restrict — 訂單一旦引用,charity 等不可 hard delete;
  // 這是會計層需求(訂單事實紀錄不能變孤兒)。
  charityId String?
  charity   Charity? @relation(fields: [charityId], references: [id], onDelete: Restrict)

  donationProjectId String?
  donationProject   DonationProject? @relation(fields: [donationProjectId], references: [id], onDelete: Restrict)

  saleItemId String?
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: Restrict)

  // 線項基本資料(application-level: quantity 1..100;§7.3 算術 invariant)。
  quantity     Int
  // CHARITY/PROJECT:= 用戶輸入金額;SALE_ITEM:= SaleItem.priceTwd 建單時 snapshot(spec 021 §3.2)。
  unitPriceTwd Int
  // = quantity × unitPriceTwd(本期 quantity 對 donation 永遠 1)。
  subtotalTwd  Int

  // 捐款 specific — 僅 subjectType ∈ {CHARITY, DONATION_PROJECT} 設(§7.2 invariant)。
  donationFrequency DonationFrequency?
  // RECURRING 必設;ONE_TIME / SALE_ITEM 必為 null。
  billingDay        BillingDay?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([charityId])
  @@index([donationProjectId])
  @@index([saleItemId])
  // admin filter「過去 X 天的某 subjectType」(spec 022 §4.7)。
  @@index([subjectType, createdAt])
  @@map("order_lines")
}
